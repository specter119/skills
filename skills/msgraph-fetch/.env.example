# Microsoft Graph Fetcher — Graph API Configuration
#
# Copy this file to .env in your project directory and fill in the values.
# The script reads from the skill .env by default, or use --env to point to
# another file.
#
# App Registration: https://entra.microsoft.com → App registrations
# Recommended delegated permissions for the full skill:
# - Sites.Read.All
# - Notes.Read.All
# - Files.Read.All

# Authority URL (tenant-specific or /common for multi-tenant)
MICROSOFT_AUTHORITY=

# Azure AD app registration client ID
MICROSOFT_CLIENT_ID=

# Refresh token — leave empty for first run (will trigger interactive login)
# Auto-updated by the script after each successful authentication
MICROSOFT_REFRESH_TOKEN=
